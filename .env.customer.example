# ================================
# FourO customer local deployment
# Copy to: .env.customer
# ================================

# ---- Public ports on customer machine
FRONT_PUBLIC_PORT=8080
BACK_PUBLIC_PORT=8011
DB_PORT=3306
REDIS_PORT=6379

# ---- Database (MySQL)
DB_USER=root
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=WEBER
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD

# ---- App secrets (must be unique per customer)
SECRET=CHANGE_ME_SECRET
JWT_SECRET=CHANGE_ME_JWT_SECRET
PASSPHRASE=CHANGE_ME_PASSPHRASE
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET

# ---- Optional app behavior / metadata
NEXT_PUBLIC_APP_RESOURCE=FourO
APP_RESOURCE=FourO
LOG_LEVEL=warn

# ---- Email (set only if customer uses email workflows)
AZURE_COMMUNICATION_CONNECTION_STRING=
AZURE_COMMUNICATION_SENDER_EMAIL=
EMAIL_FROM_EMAIL=
EMAIL_FROM_NAME=FourO Platform
ENABLE_EMAIL_VERIFICATION=true
SEND_WELCOME_EMAIL=true
EMAIL_VERIFICATION_EXPIRES_HOURS=24
PASSWORD_RESET_EXPIRES_HOURS=1

# ---- Queue/worker tuning (safe defaults)
QUEUE_CONCURRENCY=1
NOTIFICATION_QUEUE_CONCURRENCY=2
BULL_REMOVE_ON_COMPLETE=100
BULL_REMOVE_ON_FAIL=50
BULL_ATTEMPTS=5
BULL_BACKOFF_TYPE=exponential
BULL_BACKOFF_DELAY_MS=3000
BULL_TIMEOUT_MS=3600000
BULL_STALLED_INTERVAL_MS=60000
BULL_MAX_STALLED_COUNT=2
BULL_LOCK_DURATION_MS=3600000
BULL_LOCK_RENEW_TIME_MS=1800000
